# Existing application variables can remain in .env.local.

# OpenSubtitles.com REST API
# Create an application/API key in your OpenSubtitles.com account.
OPENSUBTITLES_API_KEY=
# Required by OpenSubtitles. Use a unique application name and version.
OPENSUBTITLES_USER_AGENT=UHDMovies/0.1.0
# Optional bearer token. Some download quotas/accounts require an authenticated token.
OPENSUBTITLES_TOKEN=

# SubDL developer API
# Create a free API key in the SubDL account panel.
SUBDL_API_KEY=
